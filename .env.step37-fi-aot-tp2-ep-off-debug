# =============================================================================
# DISPOSABLE / DEBUG — Step-3.7-Flash-NVFP4 dual DGX Spark GB10 TP=2
#
# Variant: "ep-off-debug" — EXPERT-PARALLEL DISABLED ISOLATION TEST
#
# Purpose: isolation experiment for the head-node memory-freeze (see
# docs/diagnostics/dgx-spark-uma-memory-freeze.md, decision table). Removes
# `--enable-expert-parallel` from VLLM_EXTRA_ARGS (the only diff vs.
# .env.step37-fi-aot-tp2-ep-debug).
#
#   - If the freeze disappears with EP off -> EP all-to-all / MoE workspace
#     / expert-map routing path is implicated.
#   - If the freeze still happens with EP off -> a UMA / page-cache / Ray /
#     KV-cache / UVM path independent of EP is implicated.
#
# !!! MEMORY TRADE-OFF WARNING !!!
# Without --enable-expert-parallel, EACH TP rank loads ALL 288 experts
# (instead of 144/rank with EP). This roughly DOUBLES the per-rank MoE
# weight footprint. GPU_MEMORY_UTILIZATION is lowered to 0.80 below as a
# starting point, but this may still fail the PRE-INIT memory check
# (`Free memory on device cuda:0 (.../121.63 GiB) on startup is less than
# desired GPU memory utilization`) -- which would actually be a CLEAN,
# fast, diagnosable failure (unlike the freeze), and is itself useful
# information. If pre-init fails, that's expected; it does not need
# further lowering to "succeed" -- the goal here is isolation, not a
# working server.
#
# DO NOT promote this file to a stable preset. Run only with
# scripts/diag/trace-memory.sh and scripts/diag/memory-guard.sh active on
# BOTH nodes, per the runbook.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v022-d568-ngc2605-tx5102-vllm022-step3p7
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/stepfun-ai/Step-3.7-Flash-NVFP4
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-NVFP4
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-NVFP4

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.80
MAX_NUM_BATCHED_TOKENS=8192

# ---- Extra args ----
# --enable-expert-parallel REMOVED (the only difference vs. ep-debug).
# Each rank now loads all 288 experts instead of 144.
VLLM_EXTRA_ARGS=--trust-remote-code --quantization modelopt --kv-cache-dtype fp8 --no-enable-flashinfer-autotune --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5 --enforce-eager

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- NVFP4 model-specific ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_GEMM_BACKEND=cutlass

# ---- Ray tuning knobs (left at defaults — isolate the EP variable only) ----
# RAY_INCLUDE_DASHBOARD=false
# RAY_OBJECT_STORE_MEMORY_BYTES=2147483648
# RAY_memory_usage_threshold=0.90
# RAY_memory_monitor_refresh_ms=1000
