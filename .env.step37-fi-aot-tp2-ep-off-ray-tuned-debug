# =============================================================================
# DISPOSABLE / DEBUG — Step-3.7-Flash-NVFP4 dual DGX Spark GB10 TP=2
#
# Variant: "ep-off-ray-tuned-debug" — Attempt 11A: EXPERT-PARALLEL DISABLED +
# RAY MEMORY-MONITOR SAFETY NET
#
# Purpose (see docs/diagnostics/dgx-spark-uma-memory-freeze.md, "Attempt 11A"):
# isolate whether the ~6-minute-post-EP-marker host memory collapse seen in
# Attempts 09 and 10b requires `--enable-expert-parallel` to be enabled.
# This is .env.step37-fi-aot-tp2-ep-off-debug (EP removed, the only diff vs.
# ep-debug) PLUS the same Ray memory-monitor knobs that converted Attempt
# 10b's collapse into a clean Ray OOM error instead of a host freeze:
#
#   - RAY_INCLUDE_DASHBOARD=false
#   - RAY_OBJECT_STORE_MEMORY_BYTES=4294967296
#   - RAY_memory_usage_threshold=0.90
#   - RAY_memory_monitor_refresh_ms=100
#   - RAY_DASHBOARD_MAX_EVENTS_TO_CACHE=1000
#
# Interpretation:
#   - EP-off removes the collapse                -> EP / all-to-all / MoE
#     workspace sizing is the key trigger.
#   - EP-off still shows the same ~6min collapse -> more likely a
#     rank0/RayWorkerWrapper/UVM/CUDA virtual-address path independent of EP
#     (see Attempt 10b's VSZ=790.6GiB finding for RayWorkerWrapper).
#   - init_device() pre-init memory check fails  -> EP-off's ~2x per-rank MoE
#     weight footprint (all 288 experts/rank instead of 144) may have pushed
#     memory requirements over GPU_MEMORY_UTILIZATION=0.85. This is a CLEAN,
#     fast, diagnosable failure and is itself a valid Attempt 11A result --
#     do NOT lower GPU_MEMORY_UTILIZATION in THIS file to "fix" it. Instead,
#     create/run a separate "Attempt 11A-fallback" env at
#     GPU_MEMORY_UTILIZATION=0.80 (e.g.
#     .env.step37-fi-aot-tp2-ep-off-ray-tuned-gpu080-debug). Results from
#     that fallback run change TWO variables vs. ep-debug (EP off AND
#     util 0.85->0.80) and must NOT be interpreted as a pure EP-only
#     isolation -- only this 0.85 run is.
#   - node0-only Ray OOM again                   -> head/rank0 asymmetry
#     persists independent of EP.
#   - node1 also becomes unstable                -> common UVM/weight-loading
#     path more likely, not head-specific.
#
# NOTE on runtime limits: this variant deliberately KEEPS
# ep-off-debug's existing MAX_MODEL_LEN=8192 / MAX_NUM_SEQS=4 /
# MAX_NUM_BATCHED_TOKENS=8192 UNCHANGED, rather than also applying Attempt
# 10b's low-kv values (4096/2/2048). Attempt 10b already showed low-kv does
# not prevent or meaningfully delay the collapse, and changing two variables
# at once (EP + KV sizing) would confound this isolation test. If you
# specifically want EP-off + low-kv combined, copy this file and apply the
# low-kv values from .env.step37-fi-aot-tp2-low-kv-ray-tuned-debug as a
# separate variant.
#
# NOTE on GPU_MEMORY_UTILIZATION: set to 0.85 here (NOT ep-off-debug's 0.80),
# matching Attempt 10b, so that EP-off is the ONLY new variable vs. Attempt
# 10b/the EP-enabled baseline. ep-off-debug's 0.80 was chosen for a
# *different* reason (headroom for EP-off's ~2x MoE weight footprint) and
# mixing it in here would confound "did EP-off change anything?" with "did
# lowering util change anything?". If init_device() fails at 0.85 with EP
# off, that is itself a valid Attempt 11A result (see Interpretation above) --
# do not lower GPU_MEMORY_UTILIZATION in this file; run a separate
# Attempt 11A-fallback env at 0.80 instead.
#
# DO NOT apply vm.min_free_kbytes=6GiB (Attempt 10a showed this causes
# init_device() to fail outright on this host's free memory). Do not lower
# GPU_MEMORY_UTILIZATION unless init_device() fails first.
#
# Optional flags NOT enabled below (verify support in this vLLM build before
# uncommenting and appending to VLLM_EXTRA_ARGS):
#
#   --kv-cache-memory-bytes <bytes>
#     Check: `docker run --rm <image> vllm serve --help | grep -i kv-cache-memory`
#
#   --all2all-backend <name>
#     Check: `docker run --rm <image> vllm serve --help | grep -i all2all`
#     Not relevant while EP is off (no all-to-all path); kept here only for
#     symmetry if this file is later copied into an EP-on variant.
#
# DO NOT promote this file to a stable preset. Run only with
# scripts/diag/trace-memory.sh and scripts/diag/memory-guard.sh active on
# BOTH nodes, per the runbook. Reboot both nodes before this run.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v022-d568-ngc2605-tx5102-vllm022-step3p7
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/stepfun-ai/Step-3.7-Flash-NVFP4
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-NVFP4
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-NVFP4

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving (MAX_MODEL_LEN/MAX_NUM_SEQS/MAX_NUM_BATCHED_TOKENS
#      unchanged from ep-off-debug; GPU_MEMORY_UTILIZATION=0.85 matches
#      Attempt 10b, NOT ep-off-debug's 0.80 -- see NOTE above) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=8192

# ---- Extra args ----
# --enable-expert-parallel REMOVED (same as ep-off-debug). Each rank loads
# all 288 experts instead of 144. --enforce-eager retained.
VLLM_EXTRA_ARGS=--trust-remote-code --quantization modelopt --kv-cache-dtype fp8 --no-enable-flashinfer-autotune --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5 --enforce-eager

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- NVFP4 model-specific ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_GEMM_BACKEND=cutlass

# ---- Ray tuning knobs (ACTIVE for this experiment, same values as
#      Attempt 10b's low-kv-ray-tuned-debug -- see docker-compose.yml for the
#      env passthroughs) ----
RAY_INCLUDE_DASHBOARD=false
RAY_OBJECT_STORE_MEMORY_BYTES=4294967296
RAY_memory_usage_threshold=0.90
RAY_memory_monitor_refresh_ms=100
RAY_DASHBOARD_MAX_EVENTS_TO_CACHE=1000
