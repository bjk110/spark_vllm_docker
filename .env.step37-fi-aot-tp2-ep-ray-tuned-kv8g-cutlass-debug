MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=8192

# ---- Extra args ----
# Attempt 14A: ONLY ADDITION vs. Attempt 13 is --moe-backend cutlass (forces
