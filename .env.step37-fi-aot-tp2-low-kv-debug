# =============================================================================
# DISPOSABLE / DEBUG — Step-3.7-Flash-NVFP4 dual DGX Spark GB10 TP=2
#
# Variant: "low-kv-debug" — LOW FIXED KV-CACHE / LOW MAX-CONTEXT ISOLATION
# TEST
#
# Purpose: same EP-enabled config as .env.step37-fi-aot-tp2-ep-debug, but
# with MAX_MODEL_LEN / MAX_NUM_SEQS / MAX_NUM_BATCHED_TOKENS reduced well
# below the baseline (8192/4/8192 -> 4096/2/2048). See
# docs/diagnostics/dgx-spark-uma-memory-freeze.md.
#
# Rationale: lowering GPU_MEMORY_UTILIZATION alone (0.88 -> 0.85 -> 0.70)
# did NOT prevent the head-node freeze, and 0.70 made it worse. That is
# weak evidence that the *KV-cache reservation itself* (sized off
# GPU_MEMORY_UTILIZATION) is not the dominant factor -- but it does not
# rule out a CPU-side allocation that scales with MAX_MODEL_LEN /
# MAX_NUM_SEQS / MAX_NUM_BATCHED_TOKENS independently of the GPU memory
# pool (e.g. CPU-side KV/blocktable bookkeeping, EP all-to-all buffers
# sized per max batched tokens). This variant shrinks those independently
# of GPU_MEMORY_UTILIZATION (kept at the same 0.85 as ep-debug) to test
# that axis.
#
# Optional flags NOT enabled below (verify support in this vLLM build
# before uncommenting and appending to VLLM_EXTRA_ARGS -- an unsupported
# flag will fail argparse immediately, which is a clean/fast failure but
# still wastes a boot cycle):
#
#   --kv-cache-memory-bytes <bytes>
#     Check: `docker run --rm <image> vllm serve --help | grep -i kv-cache-memory`
#     If present, this would let you fix the KV-cache allocation directly
#     instead of deriving it from GPU_MEMORY_UTILIZATION.
#
#   --all2all-backend <name>
#     Check: `docker run --rm <image> vllm serve --help | grep -i all2all`
#     If present, this selects the EP all-to-all communication kernel
#     (e.g. naive vs. deepep-style). Relevant only if EP all-to-all
#     workspace sizing is implicated (see ep-off-debug result first).
#
#   --enable-ep-weight-filter
#     Check: `docker run --rm <image> vllm serve --help | grep -i weight-filter`
#     If present, this may reduce per-rank weight loading for EP. Not
#     confirmed for vLLM 0.22.1 -- check availability first.
#
# DO NOT promote this file to a stable preset. Run only with
# scripts/diag/trace-memory.sh and scripts/diag/memory-guard.sh active on
# BOTH nodes, per the runbook.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v022-d568-ngc2605-tx5102-vllm022-step3p7
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/stepfun-ai/Step-3.7-Flash-NVFP4
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-NVFP4
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-NVFP4

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=4096
MAX_NUM_SEQS=2
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args (same as ep-debug: EP enabled) ----
VLLM_EXTRA_ARGS=--trust-remote-code --quantization modelopt --kv-cache-dtype fp8 --enable-expert-parallel --no-enable-flashinfer-autotune --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5 --enforce-eager

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- NVFP4 model-specific ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_GEMM_BACKEND=cutlass

# ---- Ray tuning knobs (left at defaults — isolate the KV/context axis only) ----
# RAY_INCLUDE_DASHBOARD=false
# RAY_OBJECT_STORE_MEMORY_BYTES=2147483648
# RAY_memory_usage_threshold=0.90
# RAY_memory_monitor_refresh_ms=1000
# RAY_DASHBOARD_MAX_EVENTS_TO_CACHE=1000
