# =============================================================================
# DISPOSABLE / DEBUG — Step-3.7-Flash-NVFP4 dual DGX Spark GB10 TP=2
#
# Variant: "ray-tuned-debug" — RAY OBJECT-STORE / DASHBOARD / MEMORY-MONITOR
# TUNED ISOLATION TEST
#
# Purpose: same EP-enabled config as .env.step37-fi-aot-tp2-ep-debug, but
# with Ray-side memory knobs changed (see
# docs/diagnostics/dgx-spark-uma-memory-freeze.md):
#
#   - RAY_INCLUDE_DASHBOARD=false      : drop Ray dashboard/GCS event-cache
#                                         process on head (part of the
#                                         suspected ~20GB head-only overhead)
#   - RAY_OBJECT_STORE_MEMORY_BYTES    : bound the plasma object store
#                                         instead of Ray's default
#                                         (~30% of host memory)
#   - RAY_memory_usage_threshold       : Ray memory-monitor kill threshold
#   - RAY_memory_monitor_refresh_ms    : RE-ENABLES Ray's memory monitor
#                                         (repo default is 0 = disabled).
#                                         If the monitor kills a task/actor
#                                         BEFORE the host-wide collapse, that
#                                         would point at Ray-managed memory
#                                         (object store / actor heap) as a
#                                         contributor, and would convert the
#                                         freeze into a Ray-level error
#                                         instead of an unresponsive host.
#   - RAY_DASHBOARD_MAX_EVENTS_TO_CACHE: caps dashboard event cache (no
#                                         effect if dashboard is disabled,
#                                         kept here for completeness/symmetry
#                                         if RAY_INCLUDE_DASHBOARD is later
#                                         flipped back on for A/B).
#
# NOTE: RAY_memory_monitor_refresh_ms=0 was set as a deliberate repo default
# (RAY_memory_monitor_refresh_ms=0 in docker-compose.yml). Re-enabling it
# here is itself untested for this stack -- it may change Ray's behavior in
# ways unrelated to this bug. Treat results accordingly.
#
# DO NOT promote this file to a stable preset. Run only with
# scripts/diag/trace-memory.sh and scripts/diag/memory-guard.sh active on
# BOTH nodes, per the runbook.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v022-d568-ngc2605-tx5102-vllm022-step3p7
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/stepfun-ai/Step-3.7-Flash-NVFP4
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-NVFP4
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-NVFP4

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=8192

# ---- Extra args (same as ep-debug: EP enabled) ----
VLLM_EXTRA_ARGS=--trust-remote-code --quantization modelopt --kv-cache-dtype fp8 --enable-expert-parallel --no-enable-flashinfer-autotune --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5 --enforce-eager

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- NVFP4 model-specific ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_GEMM_BACKEND=cutlass

# ---- Ray tuning knobs (ACTIVE for this experiment) ----
RAY_INCLUDE_DASHBOARD=false
RAY_OBJECT_STORE_MEMORY_BYTES=4294967296
RAY_memory_usage_threshold=0.90
RAY_memory_monitor_refresh_ms=100
RAY_DASHBOARD_MAX_EVENTS_TO_CACHE=1000
