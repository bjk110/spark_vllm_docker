# =============================================================================
# DeepSeek-V4-Flash — unholy-fusion (local-inference-lab/vllm:dev/unholy-fusion)
# Image: aidendle94/sparkrun-vllm-ds4-gb10:production-ready
# Branch: unholy-fusion-test
# Created: 2026-06-03
#
# Key differences from .env (jasl0603):
#   - Different image (unholy-fusion fork, B12X kernels)
#   - VLLM_USE_B12X_* env vars enabled
#   - VLLM_SKIP_INIT_MEMORY_CHECK: patch NOT in aidendle94 image — set 0
#   - VLLM_USE_BREAKABLE_CUDAGRAPH: unknown behavior, left unset
#   - --compilation-config, --load-format instanttensor: may need adjustment
#     depending on aidendle94 entrypoint compatibility
#
# Usage:
#   cp .env.unholy-fusion .env   (back up existing .env first!)
#   docker compose --profile head up -d
# =============================================================================

# ---- Image ----
VLLM_IMAGE=aidendle94/sparkrun-vllm-ds4-gb10:production-ready

# ---- Model ----
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-v4-flash

# ---- Cluster ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=200000
MAX_NUM_SEQS=8
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=8192

# ---- DSV4-Flash args ----
# NOTE: --load-format instanttensor and --compilation-config may not be
# supported by aidendle94 image. Remove if startup fails.
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --enable-expert-parallel --block-size 256 --tokenizer-mode deepseek_v4 --tool-call-parser deepseek_v4 --enable-auto-tool-choice --reasoning-parser deepseek_v4 --reasoning-config {"reasoning_parser":"deepseek_v4","reasoning_start_str":"<think>","reasoning_end_str":"</think>"} --default-chat-template-kwargs {"thinking":true} --load-format instanttensor --speculative-config {"method":"deepseek_mtp","num_speculative_tokens":2}

# ---- Runtime env ----
TORCH_CUDA_ARCH_LIST=12.1a
VLLM_ALLOW_LONG_MAX_MODEL_LEN=1
VLLM_TRITON_MLA_SPARSE=1
FLASHINFER_DISABLE_VERSION_CHECK=1
TILELANG_CLEANUP_TEMP_FILES=1
DG_JIT_USE_NVRTC=0
DG_JIT_NVCC_COMPILER=/usr/local/cuda/bin/nvcc
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ---- B12X kernel switches (unholy-fusion specific) ----
VLLM_USE_B12X_MOE=1
VLLM_USE_B12X_MHC=1
VLLM_USE_B12X_FP8_GEMM=1
VLLM_USE_B12X_SPARSE_INDEXER=1
VLLM_USE_B12X_WO_PROJECTION=1

# ---- Disabled / inapplicable for unholy-fusion ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
# VLLM_SKIP_INIT_MEMORY_CHECK: patch not in aidendle94 image — leave 0
VLLM_SKIP_INIT_MEMORY_CHECK=0
# VLLM_USE_BREAKABLE_CUDAGRAPH: behavior unknown in unholy-fusion — leave unset
