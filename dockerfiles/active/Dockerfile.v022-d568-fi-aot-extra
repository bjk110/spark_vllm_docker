# =========================================================================
# vLLM on NVIDIA DGX Spark (GB10, SM121) — v022-d568-fi-aot incremental addendum
#
# Incremental layer on top of vllm-spark:v022-d568-fi-aot that prebuilds 2
# additional small FlashInfer modules (13 sources total) found to still
# JIT-compile at runtime during post-weight-load profiling for
# Qwen3.6-35B-A3B (kv_cache_dtype=fp8, head_dim_qk=head_dim_vo=256, FA2
# prefill backend on GB10):
#   - batch_prefill_with_kv_cache (fa2, q=bf16, kv=e4m3, o=bf16, idx=i32,
#     head_dim 256/256, posenc=NONE, no SWA/logits-cap/f16qk) -- 10 sources
#   - sampling -- 3 sources
#
# These were discovered by diffing /root/.cache/flashinfer contents
# before/after a verification run on the first fi-aot build: with the 5
# SM120/SM121 modules prebaked, only these 2 additional modules remained to
# JIT-compile (down from ~33 nvcc/cicc processes with no AOT cache at all,
# to ~14-16 with the first fi-aot build, to (expected) 0 with this addendum).
#
# Build (spark01/spark02 only — see CLAUDE.md build-location rule):
#   docker buildx build -f dockerfiles/active/Dockerfile.v022-d568-fi-aot-extra \
#     -t vllm-spark:v022-d568-fi-aot --load .
#
# (Tag matches the base image — this is a strict superset of its cache, so
# it's a safe drop-in replacement for any preset already pointing at
# vllm-spark:v022-d568-fi-aot.)
# =========================================================================

FROM vllm-spark:v022-d568-fi-aot

# Small addendum (13 sources) — keep MAX_JOBS modest for THIS BUILD ONLY.
# (See Dockerfile.v022-d568-fi-aot: MAX_JOBS must NOT be set via ENV, or it
# persists into the runtime image and throttles vLLM's own FlashInfer JIT
# parallelism for any residual runtime-only kernel builds.)
ARG FI_AOT_MAX_JOBS=2

COPY dockerfiles/scripts/flashinfer_aot_build_extra.py /opt/flashinfer_aot_build_extra.py

RUN MAX_JOBS=${FI_AOT_MAX_JOBS} python3 /opt/flashinfer_aot_build_extra.py > /opt/flashinfer_aot_build_extra.log 2>&1 \
    || (tail -100 /opt/flashinfer_aot_build_extra.log; echo "[flashinfer-aot-extra] BUILD FAILED"; exit 1) && \
    echo "[flashinfer-aot-extra] build complete, cached .so files:" && \
    find /root/.cache/flashinfer -name "*.so" | tee -a /opt/flashinfer_aot_build_extra.log
