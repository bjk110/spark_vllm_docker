# syntax=docker/dockerfile:1.6
# =========================================================================
# DeepSeek-V4-Flash SM12x — EXPERIMENTAL build path
#
# Status: EXPERIMENTAL. Not validated, not promoted, not production.
#
# Strategy (v0.23-stack-derived, PR41834-based — NOT vLLM 0.23 itself):
#   Reuse the project's current v0.23 image TOOLCHAIN (NGC 26.05 base,
#   FlashInfer v0.6.12, Transformers 5.10.2, Triton 3.7.0, NCCL 2.30.4,
#   SM121 platform patches) exactly as Dockerfile.v023-d568 does, but build
#   vLLM from the pinned DeepSeek-V4 SM12x source instead of v0.23.0.
#
#   vLLM source: vLLM PR #41834 head (jasl/vllm codex/ds4-sm120-min-enable),
#     pinned commit 72261a7af149fa5d3fe2ed2b9956e92590731012
#     (preview tag sm120-pr-41834-stable-preview-20260621 dereferences to it).
#     PR #41834 is OPEN/experimental. The pinned commit is 586 commits ahead of
#     and 6 behind v0.23.0 (diverged) — it is a post-0.23.0 main snapshot plus
#     126 DeepSeek-V4 commits, so this image is NOT vLLM 0.23.0.
#
#   Excludes the Step-3.7 tokenizer overlay and all Step-3.7-specific model
#   behavior (none of which are in the reused base anyway).
#
# Build-time compatibility notes (see docs/deepseek-v4-v023-stack-pr41834.md):
#   - FlashInfer 0.6.12 == the pinned source requirement (exact match).
#   - Transformers 5.10.2 satisfies the source's `>= 5.5.3`.
#   - Python 3.12 satisfies the source's `>=3.10,<3.15`.
#   - The source's requirements pin torch==2.11.0, but (as for v0.23.0) vLLM is
#     built from source against the NGC 26.05 bundled PyTorch 2.12.0a0. RISK:
#     torch ABI/API drift; this is the same source-build pattern already used
#     for the v0.23.0 image.
#   - NEW dependency: nvidia-cutlass-dsl[cu13]==4.5.2 (pinned below).
#   - DeepGEMM is NOT natively available on SM120/121; the pinned source ships
#     Triton/torch fallbacks (sm12x_deep_gemm_fallbacks.py). Do NOT force it.
#
# Build (later stage — do NOT build in the preparation task):
#   docker buildx build -f dockerfiles/active/Dockerfile.v023-stack-dsv4-sm12x-pr41834 \
#     -t vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7 --load .
# =========================================================================

ARG NGC_TAG=26.05-py3
ARG BUILD_JOBS=16

# Pinned versions — keep the v0.23 toolchain; only the vLLM source changes.
ARG VLLM_REPO_URL=https://github.com/vllm-project/vllm.git
ARG VLLM_PR=41834
ARG VLLM_COMMIT=72261a7af149fa5d3fe2ed2b9956e92590731012
# NOT 0.23.0 — a documented experimental pretend-version (source is main-based,
# post-0.23.0). setuptools-scm cannot parse the preview tag, so pin explicitly.
ARG VLLM_VERSION=0.24.0.dev0+dsv4.pr41834.72261a7
ARG FLASHINFER_REF=v0.6.12
ARG TRANSFORMERS_VER=5.10.2
ARG CUTLASS_DSL_REQ=nvidia-cutlass-dsl[cu13]==4.5.2
ARG TORCH_CUDA_ARCH="12.1a"

# =========================================================================
# STAGE 1: FlashInfer Builder (identical to the v0.23 base toolchain)
# =========================================================================
FROM nvcr.io/nvidia/pytorch:${NGC_TAG} AS flashinfer-builder

ARG BUILD_JOBS
ARG FLASHINFER_REF
ARG TORCH_CUDA_ARCH
ENV MAX_JOBS=${BUILD_JOBS} \
    CMAKE_BUILD_PARALLEL_LEVEL=${BUILD_JOBS} \
    DEBIAN_FRONTEND=noninteractive \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_BREAK_SYSTEM_PACKAGES=1 \
    UV_LINK_MODE=copy \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH} \
    FLASHINFER_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH} \
    PATH=/usr/lib/ccache:$PATH \
    CCACHE_DIR=/root/.ccache \
    CCACHE_MAXSIZE=50G \
    CCACHE_COMPRESS=1 \
    CMAKE_CXX_COMPILER_LAUNCHER=ccache \
    CMAKE_CUDA_COMPILER_LAUNCHER=ccache

RUN apt-get update && \
    apt-get install -y --no-install-recommends ninja-build git ccache && \
    rm -rf /var/lib/apt/lists/* && \
    pip install uv && pip uninstall -y flash-attn 2>/dev/null || true

RUN --mount=type=cache,id=uv-dsv4-pr41834,target=/root/.cache/uv \
# NOTE: build-env only; the FINAL runtime apache-tvm-ffi is pinned ==0.1.9 in
# the runner stage (the flashinfer wheel does not embed tvm-ffi; CuTeDSL is a
# runtime JIT dep). Keep this RUN byte-identical to preserve the build cache.
    uv pip install --system nvidia-nvshmem-cu13 "apache-tvm-ffi<0.2"

RUN --mount=type=cache,id=git-fi-dsv4-pr41834,target=/git-cache/flashinfer \
    if [ -d /git-cache/flashinfer/.git ]; then \
        cp -a /git-cache/flashinfer /workspace/flashinfer && \
        cd /workspace/flashinfer && git fetch origin --tags; \
    else \
        git clone https://github.com/flashinfer-ai/flashinfer.git /workspace/flashinfer && \
        cp -a /workspace/flashinfer /git-cache/flashinfer; \
    fi && \
    cd /workspace/flashinfer && git checkout ${FLASHINFER_REF} && \
    git submodule update --init --recursive

COPY patches/flashinfer/flashinfer_cache.patch /workspace/flashinfer/
RUN cd /workspace/flashinfer && \
    (patch -p1 --dry-run < flashinfer_cache.patch &>/dev/null && \
     patch -p1 < flashinfer_cache.patch || echo "[flashinfer] cache patch not applicable")

WORKDIR /workspace/flashinfer
RUN --mount=type=cache,id=uv-dsv4-pr41834,target=/root/.cache/uv \
    --mount=type=cache,id=ccache-dsv4-pr41834,target=/root/.ccache \
    sed -i -e 's/license = "Apache-2.0"/license = { text = "Apache-2.0" }/' \
           -e '/license-files/d' pyproject.toml 2>/dev/null || true && \
    uv build --no-build-isolation --wheel . --out-dir=/workspace/wheels -v

RUN --mount=type=cache,id=uv-dsv4-pr41834,target=/root/.cache/uv \
    --mount=type=cache,id=ccache-dsv4-pr41834,target=/root/.ccache \
    for subpkg in flashinfer-cubin flashinfer-jit-cache; do \
        if [ -d "$subpkg" ]; then \
            echo "[flashinfer] Building $subpkg..." && \
            cd /workspace/flashinfer/$subpkg && \
            uv build --no-build-isolation --wheel . --out-dir=/workspace/wheels -v || \
            echo "[flashinfer] $subpkg build failed (optional)"; \
        fi; \
    done


# =========================================================================
# STAGE 2: vLLM Builder — pinned to PR #41834 head (DeepSeek-V4 SM12x)
# =========================================================================
FROM nvcr.io/nvidia/pytorch:${NGC_TAG} AS vllm-builder

ARG BUILD_JOBS
ARG VLLM_REPO_URL
ARG VLLM_PR
ARG VLLM_COMMIT
ARG VLLM_VERSION
ARG TORCH_CUDA_ARCH
ENV MAX_JOBS=${BUILD_JOBS} \
    DEBIAN_FRONTEND=noninteractive \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH} \
    PATH=/usr/lib/ccache:$PATH \
    CCACHE_DIR=/root/.ccache \
    CCACHE_MAXSIZE=50G \
    CCACHE_COMPRESS=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends git ninja-build ccache && \
    rm -rf /var/lib/apt/lists/*

# Clone vLLM, fetch the PR head, and pin to the EXACT commit. Fail the build on
# any mismatch (no moving branch heads).
RUN git clone ${VLLM_REPO_URL} /workspace/vllm-src && \
    cd /workspace/vllm-src && \
    git fetch origin pull/${VLLM_PR}/head && \
    git checkout ${VLLM_COMMIT} && \
    ACTUAL=$(git rev-parse HEAD) && \
    echo "vLLM pinned to: ${ACTUAL} (PR #${VLLM_PR})" && \
    [ "${ACTUAL}" = "${VLLM_COMMIT}" ] || \
      (echo "FATAL: commit mismatch — expected ${VLLM_COMMIT}, got ${ACTUAL}" && exit 1)

RUN pip install -q setuptools "setuptools-scm>=8" setuptools-rust ninja cmake wheel packaging jinja2 regex

# NGC 26.05 PyTorch 2.12.0a0 alpha removes the hoist kwarg from
# register_opaque_type() (same as the v0.23 base build).
COPY patches/common/fix_pytorch211_compat.py /tmp/fix_pytorch211_compat.py
RUN python3 /tmp/fix_pytorch211_compat.py || \
    echo "[patch] fix_pytorch211_compat not applicable on this source"

# Build vLLM wheel from the pinned PR source (includes the DeepSeek-V4 SM12x
# native extensions under vllm/models/deepseek_v4/...).
RUN --mount=type=cache,id=ccache-dsv4-pr41834,target=/root/.ccache \
    cd /workspace/vllm-src && \
    SETUPTOOLS_SCM_PRETEND_VERSION="${VLLM_VERSION}" \
    VLLM_TARGET_DEVICE=cuda \
    python3 setup.py bdist_wheel -d /workspace/wheels && \
    ls -lh /workspace/wheels/*.whl && \
    echo "[vllm] DeepSeek-V4 SM12x wheel built (PR #${VLLM_PR} @ ${VLLM_COMMIT})"


# =========================================================================
# STAGE 3: Runner (same toolchain layers as the v0.23 base)
# =========================================================================
FROM nvcr.io/nvidia/pytorch:${NGC_TAG} AS runner

ARG VLLM_REPO_URL
ARG VLLM_PR
ARG VLLM_COMMIT
LABEL org.opencontainers.image.source="https://github.com/bjk110/spark_vllm_docker"
LABEL org.opencontainers.image.description="EXPERIMENTAL DeepSeek-V4-Flash SM12x: vLLM PR #41834 @ 72261a7 (v0.23-stack-derived, NOT vLLM 0.23) + FlashInfer v0.6.12 + NGC 26.05 (PyTorch 2.12.0a0, CUDA 13.2) + Transformers 5.10.2 + Triton 3.7.0 + NCCL 2.30.4 on DGX Spark (GB10/SM121)"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.vllm-spark.experimental="true"
LABEL org.vllm-spark.vllm-source-repo="${VLLM_REPO_URL}"
LABEL org.vllm-spark.vllm-source-pr="${VLLM_PR}"
LABEL org.vllm-spark.vllm-source-commit="${VLLM_COMMIT}"
LABEL org.vllm-spark.vllm-source-tag="sm120-pr-41834-stable-preview-20260621"
LABEL org.vllm-spark.derived-from="v0.23-image-stack (NGC 26.05); vLLM source replaced with PR #41834 head"
LABEL org.vllm-spark.repo-baseline-commit="9ceabf3f7d85be18c6c14233e9af4bf1870bfe22"
LABEL org.vllm-spark.model="deepseek-ai/DeepSeek-V4-Flash"

ARG TORCH_CUDA_ARCH
ENV DEBIAN_FRONTEND=noninteractive \
    PIP_BREAK_SYSTEM_PACKAGES=1 \
    UV_SYSTEM_PYTHON=1 \
    UV_BREAK_SYSTEM_PACKAGES=1 \
    UV_LINK_MODE=copy \
    VLLM_BASE_DIR=/workspace/vllm \
    TORCH_CUDA_ARCH_LIST=${TORCH_CUDA_ARCH} \
    TRITON_PTXAS_PATH=/usr/local/cuda/bin/ptxas

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl vim git libxcb1 && \
    rm -rf /var/lib/apt/lists/* && \
    pip install uv && pip uninstall -y flash-attn 2>/dev/null || true

WORKDIR ${VLLM_BASE_DIR}

RUN mkdir -p tiktoken_encodings && \
    wget -qO tiktoken_encodings/o200k_base.tiktoken \
      "https://openaipublic.blob.core.windows.net/encodings/o200k_base.tiktoken" && \
    wget -qO tiktoken_encodings/cl100k_base.tiktoken \
      "https://openaipublic.blob.core.windows.net/encodings/cl100k_base.tiktoken"
ENV TIKTOKEN_ENCODINGS_BASE=${VLLM_BASE_DIR}/tiktoken_encodings

# ---- Install FlashInfer (v0.6.12, identical to the v0.23 base) ----
RUN --mount=type=bind,from=flashinfer-builder,source=/workspace/wheels,target=/mount/fi \
    pip install /mount/fi/*.whl 2>/dev/null || \
    pip install /mount/fi/flashinfer_python*.whl /mount/fi/flashinfer_cubin*.whl 2>/dev/null || \
    (echo "FATAL: FlashInfer install failed" && exit 1)

# ---- Install vLLM (PR #41834 DeepSeek-V4 SM12x wheel) ----
RUN --mount=type=bind,from=vllm-builder,source=/workspace/wheels,target=/mount/vllm \
    pip install /mount/vllm/*.whl --no-deps && \
    python3 -c "import vllm, vllm.version; print('[vllm]', vllm.__version__)"

# ---- Runtime dependencies (source-declared, minus torch/flashinfer) ----
# Adds the new pinned CUTLASS DSL dependency required by the SM12x source, plus
# compressed-tensors for the W4A16-FP8 mixed-precision checkpoint variant.
ARG CUTLASS_DSL_REQ
RUN --mount=type=cache,id=uv-dsv4-pr41834,target=/root/.cache/uv \
    DEPS=$(pip show vllm 2>/dev/null | grep ^Requires | sed 's/Requires: //' | tr ',' '\n' | \
      sed 's/^ *//;s/ *$//' | grep -v -E '^(torch|torchvision|torchaudio|flashinfer|$)' | \
      tr '\n' ' ') && \
    uv pip install --system $DEPS ray[default] fastsafetensors nvidia-nvshmem-cu13 uvloop && \
    uv pip install --system "${CUTLASS_DSL_REQ}" --no-deps && \
    uv pip install --system "compressed-tensors==0.15.0.1" --no-deps

# ---- Coordinate the TVM-FFI family to the EXACT source-pinned versions ----
# The vLLM PR source declares `apache-tvm-ffi==0.1.9` AND `tilelang==0.1.9` as a
# COORDINATED set. The name-only $DEPS install above resolves them to the latest
# (apache-tvm-ffi 0.1.12, tilelang 0.1.11), and tilelang>=0.1.10 in turn requires
# apache-tvm-ffi>=0.1.10, so the family becomes incoherent. tilelang IS loaded on
# the DeepSeek-V4 sparse path (vllm.model_executor.kernels.mhc.tilelang), and
# `__ffi_repr__` is registered only by apache-tvm-ffi's libtvm_ffi.so; the drift
# made a second, mismatched consumer re-register it at JIT time → C++ abort
# ("TypeAttr __ffi_repr__ is already registered for type index 130") during the
# DEEPSEEK_SPARSE_SWA profiling forward pass. Pin BOTH to the source-coordinated
# 0.1.9 and verify the resulting versions and pip metadata are coherent.
RUN --mount=type=cache,id=uv-dsv4-pr41834,target=/root/.cache/uv \
    uv pip install --system "apache-tvm-ffi==0.1.9" "tilelang==0.1.9" && \
    python3 -c "import importlib.metadata as md; a=md.version('apache-tvm-ffi'); t=md.version('tilelang'); assert a=='0.1.9' and t=='0.1.9', f'tvm family drift: apache-tvm-ffi={a} tilelang={t}'; print('[verify] apache-tvm-ffi', a, 'tilelang', t)" && \
    ( python3 -m pip check 2>&1 | grep -iE 'apache-tvm-ffi|tilelang' && (echo 'FATAL: residual TVM-family pip conflict' && exit 1) || echo '[verify] no TVM-family pip conflict' )

# ---- Transformers (pinned, satisfies the source's >= 5.5.3) ----
ARG TRANSFORMERS_VER
RUN uv pip install transformers==${TRANSFORMERS_VER} --upgrade --no-deps --system && \
    uv pip install huggingface-hub --upgrade --no-deps --system

# ---- GB10-tuned DeepSeek-V4 MoE configs (E=256 matches the checkpoint) ----
COPY patches/dsv4/moe_config_e256.json \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/configs/E=256,N=512,device_name=NVIDIA_GB10,dtype=fp8_w8a8,block_shape=[128,128].json
COPY patches/dsv4/moe_config_e512.json \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/fused_moe/configs/E=512,N=512,device_name=NVIDIA_GB10,dtype=fp8_w8a8,block_shape=[128,128].json

# ---- SM121 / GB10 platform patches (none merged upstream; toolchain parity) ----
COPY patches/sm121/apply_sm121_patches.py /tmp/
RUN python3 /tmp/apply_sm121_patches.py || echo "[patch] SM121 partial"

COPY patches/turboquant/apply_turboquant_fixes.py /tmp/
RUN python3 /tmp/apply_turboquant_fixes.py || echo "[patch] turboquant not applicable on this source"

COPY patches/common/patch_split_module_compat.py /tmp/
RUN python3 /tmp/patch_split_module_compat.py || echo "[patch] split_module compat not applicable"

RUN uv pip uninstall triton-kernels 2>/dev/null || true

# ---- Triton 3.7.0 (NGC base bundles 3.6.0) ----
ARG TRITON_VER=3.7.0
RUN uv pip install triton==${TRITON_VER} --upgrade --no-deps --system && \
    python3 -c "import triton; print(f'[triton] installed {triton.__version__}')"

# ---- NCCL 2.30.4 (NGC bundles it; pip kept for LD_LIBRARY_PATH parity) ----
ARG NCCL_VER=2.30.4
RUN uv pip install nvidia-nccl-cu13==${NCCL_VER} --upgrade --no-deps --system && \
    NCCL_LIB_DIR=$(find /usr/local/lib/python3.12/dist-packages/nvidia/nccl/lib /usr/local/lib/python3.12/dist-packages/nvidia_nccl_cu13/lib 2>/dev/null | grep -m1 'lib$') && \
    echo "${NCCL_LIB_DIR}" > /etc/ld.so.conf.d/zz-nvidia-nccl-cu13.conf && \
    ldconfig
ENV LD_LIBRARY_PATH=/usr/local/lib/python3.12/dist-packages/nvidia/nccl/lib:$LD_LIBRARY_PATH

# ---- Deterministic source-revision marker (English; proves the pinned source) ----
RUN printf '%s\n' "72261a7af149fa5d3fe2ed2b9956e92590731012" > /opt/vllm-source-revision

# ---- Runtime helper scripts (kept for runtime use; NOT the build gate) ----
# The shared scripts/verify_imports.py is left available but is NOT used as the
# build gate: it hard-requires the legacy vllm._C / _C.abi3.so layout, which the
# pinned post-v0.23 source (72261a7) replaced with the consolidated
# vllm._C_stable_libtorch / _C_stable_libtorch.abi3.so extension.
COPY scripts/verify_imports.py /opt/scripts/verify_imports.py
COPY scripts/verify_runtime.sh /opt/scripts/verify_runtime.sh
RUN chmod +x /opt/scripts/verify_runtime.sh

# ---- Build-time sanity (no GPU; source-layout-aware; no CUDA init / no model) ----
# Proves: vllm imports, the compiled libtorch-stable extension .so exists, the
# installed source revision matches the pin (marker file + version local SHA),
# and DeepseekV4ForCausalLM is registered. The extension .so dlopen()s
# libcuda.so.1, which is absent in the CPU-only builder, so a missing-libcuda
# import error here is tolerated (the real symbol load is proven in the GPU
# capability smoke test); any OTHER import error fails the build.
RUN python3 <<'PY'
import glob, importlib, os, sys
REV = "72261a7af149fa5d3fe2ed2b9956e92590731012"

import vllm
print("[verify] vllm_version =", vllm.__version__)
print("[verify] vllm_path    =", os.path.dirname(vllm.__file__))

# Required compiled extension (NOT the legacy vllm._C / _C.abi3.so).
so = glob.glob(os.path.join(os.path.dirname(vllm.__file__), "_C_stable_libtorch*.so"))
assert so, "FAIL: _C_stable_libtorch*.so not present (compilation did not produce the extension)"
print("[verify] extension_so  =", so[0], f"({os.path.getsize(so[0])/1e6:.1f} MB)")

try:
    ext = importlib.import_module("vllm._C_stable_libtorch")
    print("[verify] extension_module =", ext.__file__, "(imported)")
except Exception as e:
    msg = str(e)
    if "libcuda.so.1" in msg:
        print("[verify] extension import DEFERRED to GPU smoke (no libcuda in builder):", msg)
    else:
        print("FAIL: unexpected extension import error:", msg); sys.exit(1)

# Source revision proof: deterministic marker file + version local metadata.
marker = open("/opt/vllm-source-revision").read().strip()
assert marker == REV, f"FAIL: revision marker {marker} != {REV}"
assert "72261a7" in vllm.__version__, f"FAIL: version {vllm.__version__} lacks source short SHA"
print("[verify] source_revision =", marker)

# DeepSeek-V4 registry (no CUDA init, no instantiation, no weight load).
from vllm.model_executor.models.registry import ModelRegistry
archs = ModelRegistry.get_supported_archs()
assert "DeepseekV4ForCausalLM" in archs, "FAIL: DeepseekV4ForCausalLM not registered"
print("[verify] DeepseekV4ForCausalLM registered")
print("[verify] Build-time checks passed (source-layout-aware gate)")
PY

COPY scripts/run-cluster-node.sh ${VLLM_BASE_DIR}/
RUN chmod +x ${VLLM_BASE_DIR}/run-cluster-node.sh
ENV PATH=${VLLM_BASE_DIR}:$PATH

EXPOSE 8000
