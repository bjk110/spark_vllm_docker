# =============================================================================
# DeepSeek-V4-Flash — EXPERIMENTAL TP2 on 2× GB10 (Spark pair)
#
# Recipe reference: https://recipes.vllm.ai/deepseek-ai/DeepSeek-V4-Flash
# Recipe targets H200/B200/B300 with DP=4 + EP + Mooncake PD. This preset
# scales down to 2× GB10 with TP=2 + EP=2 (no DP, no PD, no Mooncake).
#
# Model: DeepSeek-V4-Flash (284B total / 13B active, FP4+FP8 mixed, 1M context)
#   n_routed_experts=256, num_experts_per_tok=6, n_shared_experts=1
#   FP8 attention/norm/router + FP4 MoE experts (from config.json)
#
# Starting flags are conservative for dry-run; see scripts/run_deepseek_v4_flash_spark0{1,2}.sh
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:deepseek-v4-exp

# ---- Model ----
# Host path — rsync scripts place the model at this location on both Sparks.
# Spark nodes don't have /mnt/data mounted; models live under
# /home/bjk110/Documents/Models/ per the existing repo convention.
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/deepseek-ai_DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# ---- Cluster (2× GB10 multi-node via Ray) ----
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving (conservative initial values per user spec) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
MAX_NUM_BATCHED_TOKENS=4096
GPU_MEMORY_UTILIZATION=0.90

# ---- V4-specific vllm serve flags ----
# Minimum viable flag set from recipe (excluding DP=4 / PD / Mooncake):
#   --trust-remote-code
#   --kv-cache-dtype fp8
#   --block-size 256
#   --enable-expert-parallel
#   --tokenizer-mode deepseek_v4
#   --reasoning-parser deepseek_v4
#   --enforce-eager
#   --no-disable-hybrid-kv-cache-manager
#   --disable-uvicorn-access-log
#
# NOT included initially (per user spec):
#   --data-parallel-size 4      (we have 2 GPUs; TP=2 + EP=2 instead)
#   --max-model-len auto        (use explicit 8192 for first boot)
#   --kv-transfer-config ...    (no Mooncake / PD disagg)
VLLM_EXTRA_ARGS=--trust-remote-code --kv-cache-dtype fp8 --block-size 256 --enable-expert-parallel --tokenizer-mode deepseek_v4 --reasoning-parser deepseek_v4 --enforce-eager --no-disable-hybrid-kv-cache-manager --disable-uvicorn-access-log

# ---- Runtime env for V4 / tilelang ----
# Passed via run scripts, not consumed here. See scripts/run_deepseek_v4_flash_spark0{1,2}.sh

# ---- Disable unrelated model-specific toggles ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0
APPLY_TEXT_ONLY_SHIM=0
