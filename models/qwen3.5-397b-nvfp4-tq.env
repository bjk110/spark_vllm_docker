# =============================================================================
# nvidia/Qwen3.5-397B-A17B-NVFP4 — TP2 Multi-Node (spark01 + spark02)
# MoE: 397B total / 17B active, NVFP4 + TurboQuant KV cache (4-bit)
# head_dim=256, num_kv_heads=2, 60 layers, hybrid (attention+Mamba+GDN+MoE)
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:turboquant

# ---- Model ----
MODEL_PATH=[model_path]/Qwen/nvidia_Qwen3.5-397B-A17B-NVFP4
MODEL_CONTAINER_PATH=/models/nvidia_Qwen3.5-397B-A17B-NVFP4
SERVED_MODEL_NAME=nvidia/Qwen3.5-397B-A17B-NVFP4

# ---- Cluster ----
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.90
MAX_NUM_BATCHED_TOKENS=8192

# ---- Extra args (TurboQuant KV cache + reasoning) ----
VLLM_EXTRA_ARGS=--enable-chunked-prefill --kv-cache-dtype turboquant --reasoning-parser qwen3

# ---- TurboQuant tuning ----
TQ_CUDA_WPH=1
TQ_WPH_WARPS=4

# ---- Model-specific env vars ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_MOE_FORCE_MARLIN=0
