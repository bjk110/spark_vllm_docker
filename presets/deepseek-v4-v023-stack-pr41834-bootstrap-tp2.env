# =============================================================================
# deepseek-ai/DeepSeek-V4-Flash — SM12x EXPERIMENTAL bootstrap (vLLM PR #41834)
#
# Status: EXPERIMENTAL. Not validated, not promoted, not production.
#
# Minimal first bring-up preset for the v0.23-stack-derived, PR41834-based image
# (NOT vLLM 0.23 itself). Goal: the smallest conservative configuration that can
# load and serve at all, so any failure is easy to isolate. Two follow-on
# presets change exactly one axis each (graph / prefix-cache) — do not combine.
#
# Image (validated experimental; built from
#   dockerfiles/active/Dockerfile.v023-stack-dsv4-sm12x-pr41834 with the
#   TVM-family pin fix, apache-tvm-ffi==0.1.9 + tilelang==0.1.9):
#   vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
#   local/config id sha256:4c41950c47ecb771eead3e32147a750240d6605d15ee99c54b43e0a85ea26105
#   GHCR: ghcr.io/bjk110/vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
#   vLLM source: PR #41834 head @ 72261a7af149fa5d3fe2ed2b9956e92590731012. PR is OPEN.
#   NOTE: the suffixless base tag ...-exp-72261a7 (image 3cb14c02) is the OLD
#   pre-fix build that aborts at sparse profiling — do NOT use it.
#
# Model (bootstrap targets the upstream FP8 base checkpoint — pure block-FP8,
#   the simplest dispatch; the W4A16-FP8 mixed INT4/FP8 checkpoint is a separate
#   later experiment): deepseek-ai/DeepSeek-V4-Flash, DeepseekV4ForCausalLM,
#   bf16 base, 43 layers, 256 routed experts top-6 + 1 shared, FP8 block
#   [128,128] e4m3 dynamic, max_position_embeddings 1,048,576 (NOT used here).
#
# Deferred (NOT enabled here — see docs/deepseek-v4-v023-stack-pr41834.md):
#   MTP, 1M context, async scheduling, scheduler fairness heuristics, FlashInfer
#   SM120 decode/prefill opt-in, DeepGEMM forcing (SM120 has fallbacks only),
#   experimental NVFP4 GEMM override, custom PCIe all-reduce, B12X flags
#   (VLLM_USE_B12X_MOE is NOT present in the pinned source — do not add it).
#
# Startup requires a clean-memory preflight (~116-117 GiB CUDA-free/node). Do
#   NOT use VLLM_SKIP_INIT_MEMORY_CHECK. Request approval before any reboot.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
# Standard entrypoint — NO Step-3.7 tokenizer overlay (DeepSeek-V4 ships its own
# tokenizer; the overlay is Step-3.7-specific and must not be reused here).
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model (bootstrap = FP8 base checkpoint) ----
MODEL_PATH=[model_path]/deepseek-ai/deepseek-ai_DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# ---- Cluster (dual DGX Spark, RoCE 200 Gbps, mp SPMD backend, no Ray) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving (conservative bootstrap) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args ----
# Conservative bootstrap:
#   --enforce-eager            : CUDA graph OFF (graph is a separate experiment).
#   --no-enable-prefix-caching : prefix cache OFF (separate experiment).
#   --kv-cache-memory-bytes    : fixed 2 GiB KV pool (deterministic; avoids the
#                                profiling-run memory spike). Adjust upward only
#                                after a clean bring-up.
#   --skip-mm-profiling        : DeepSeek-V4-Flash is text-only here.
#   EP / MTP / sparse-MLA opt-ins / FlashInfer SM120 opt-ins: NOT added — let the
#     pinned source auto-select its DeepSeek-V4 path. Record the chosen MoE and
#     attention backends from the startup log to verify (expected: a DeepSeek-V4
#     sparse-MLA attention path + FP8 fused MoE; confirm against logs).
#   Reasoning / tool parsers: NOT set here — confirm the registered DeepSeek-V4
#     parser names from the pinned source, then add in a follow-up.
VLLM_EXTRA_ARGS=--enforce-eager --no-enable-prefix-caching --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- vLLM SM_121 guards (v0.23-stack) ----
# Breakable CUDA graph default-on garbles on SM_121; keep disabled even though
# enforce-eager already prevents capture (belt-and-suspenders for the graph
# experiment that reuses this base).
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- Explicitly NOT set ----
# VLLM_SKIP_INIT_MEMORY_CHECK  : forbidden — rely on a clean-memory preflight.
# VLLM_USE_B12X_MOE / *_B12X_*  : not implemented in the pinned source.
# VLLM_PREFIX_CACHE_RETENTION_INTERVAL : prefix-cache experiment only.
