# =============================================================================
# deepseek-ai/DeepSeek-V4-Flash — SM12x EAGER U0-RDMA ROLLBACK (vLLM PR #41834)
#
# Status: VALIDATED_ROLLBACK_PRESET (Rollback level 2). NOT production.
#   The most conservative DSV4 serving mode: no MTP, no CUDA graph (enforce-eager),
#   NET/IB over RoCE. Lowest graph/speculative-state complexity; use when the validated
#   MTP+FULL-graph preset OR the graph-only rollback (level 1) must be backed out.
#
# Why this file exists: the existing
#   presets/deepseek-v4-v023-stack-pr41834-bootstrap-tp2.env
# is a TEMPLATE (NCCL_NET=Socket, IB_HCA_NAME=<IB_HCA_NAME> placeholder) and is NOT a
# runnable NET/IB eager baseline. This preset is a concrete, NET/IB, no-placeholder
# rollback target derived from the validated preset's exact transport/runtime stack.
#
# Lineage / immutable identity (identical image + model to the validated preset):
#   model           deepseek-ai/DeepSeek-V4-Flash (official FP8, 46 shards, ~148.7 GiB)
#   image config ID sha256:4c41950c47ecb771eead3e32147a750240d6605d15ee99c54b43e0a85ea26105
#   local tag       vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
#   pinned source   72261a7af149fa5d3fe2ed2b9956e92590731012
#
# Normalized runtime delta vs the validated preset
#   presets/deepseek-v4-v023-stack-pr41834-mtp1-fullgraph-validated-tp2.env:
#   VLLM_EXTRA_ARGS only —
#     - REMOVE  --speculative-config {"method":"deepseek_mtp","num_speculative_tokens":1}
#     - REMOVE  --compilation-config {"cudagraph_mode":"FULL_DECODE_ONLY",...}
#     + ADD     --enforce-eager
#   Everything else (image, NET/IB transport, HCA rocep1s0f0, TP=2 mp, EP/prefix/parser/
#   tool-parser/B12X/Ray off, fixed KV 2 GiB fp8, max-model-len 8192, max-seqs 1,
#   max-batched-tokens 2048, GPU util 0.87, BREAKABLE_CUDAGRAPH=0) is IDENTICAL.
#   VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS and VLLM_USE_BREAKABLE_CUDAGRAPH are no-ops
#   under enforce-eager; kept for file uniformity.
#
# Expected behaviour (validated lineage U0-RDMA eager): decode ~7.4 t/s (lowest of the
#   three levels), no graph capture, no speculative state, simplest memory profile.
#   Same two-node topology, clean-boot, and dedicated-cache-clear prerequisites as the
#   validated preset apply. Single-node TP=1 is IMPOSSIBLE for the official checkpoint.
#
# When to use: a graph-capture, speculative/rejection, or MTP-init fault that also
#   affects the graph-only rollback (level 1); maximal-stability fallback while
#   diagnosing. See docs/deepseek-v4-mtp1-fullgraph-validated-preset.md for the full
#   bounded rollback procedure (reboot if UVM-retained, cache clear, hash verify,
#   correctness gate, transport proof, eager-mode proof, record reason).
# =============================================================================

VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
ENTRYPOINT_FILE=./entrypoints/entrypoint-rdma.sh
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048
VLLM_EXTRA_ARGS=--enforce-eager --no-enable-prefix-caching --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2
