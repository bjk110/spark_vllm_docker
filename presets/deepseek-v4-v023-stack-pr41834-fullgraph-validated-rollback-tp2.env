# =============================================================================
# deepseek-ai/DeepSeek-V4-Flash — SM12x GRAPH-ONLY FULL_DECODE_ONLY ROLLBACK (PR #41834)
#
# Status: VALIDATED_ROLLBACK_PRESET (Rollback level 1). NOT production.
#   FULL_DECODE_ONLY attention-capturing decode graph with MTP DISABLED. Intermediate
#   conservative mode between the primary MTP+FULL-graph validated preset and the eager
#   level-2 rollback: keeps the decode CUDA graph (lower host-dispatch overhead) but
#   removes all speculative/MTP state. Use when a speculative-decode / MTP-init fault
#   must be backed out while the FULL decode graph itself remains stable.
#
# Why this file exists: the tested graph-only configuration was validated from a
# DISPOSABLE / untracked safety preset
#   presets/deepseek-v4-v023-stack-pr41834-fullgraph-safety-f2-tp2.env
#   (SHA-256 61468aeff7faf8f4acf30f764d3d6a09ca0d7affd371d0fb83845a111b4896b6).
# A committed provenance document must not point operators at an uncommitted asset, so
# this formally named rollback preset is the repository-tracked operational target. Its
# runtime (env) section is BYTE-IDENTICAL to that tested safety preset; only the header
# comments / status wording / provenance links differ (normalized runtime diff EMPTY).
#
# Lineage / immutable identity (identical image + model to the validated preset):
#   model           deepseek-ai/DeepSeek-V4-Flash (official FP8, 46 shards, ~148.7 GiB)
#   image config ID sha256:4c41950c47ecb771eead3e32147a750240d6605d15ee99c54b43e0a85ea26105
#   local tag       vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
#   pinned source   72261a7af149fa5d3fe2ed2b9956e92590731012
#
# Validated configuration: MTP OFF; FULL_DECODE_ONLY; capture size [1] (MTP off →
#   uniform_decode_query_len = 1, so [1] is the correct single decode-graph size — this
#   differs from the MTP preset's mandatory [2]); TP=2 mp; NET/IB over RoCE (HCA
#   rocep1s0f0, no Socket fallback); EP off; prefix off; parser off; tool parser off;
#   B12X off; Ray off; fixed KV 2 GiB; KV fp8; FlashMLA sparse-MLA; max-model-len 8192;
#   max-seqs 1; max-batched-tokens 2048; concurrency 1; VLLM_USE_BREAKABLE_CUDAGRAPH=0;
#   init-memory-check bypass DISABLED.
#
# Expected performance: decode ~27.2 t/s (no speculative acceleration; the MTP+FULL
#   validated preset reaches ~38.9-40.2 / 37.1-39.8 t/s). Lower memory and speculative-
#   state complexity than the primary preset.
#
# Operational prerequisites (same as the validated preset; NOT automated here):
#   clean boot before every full model load (reboot BOTH nodes once if MemAvailable
#   < 110 GiB due to GB10 UMA retention); clear ONLY the dedicated vLLM compilation
#   cache (./.cache/vllm) on BOTH nodes; keep default FlashMLA backend. Single-node
#   TP=1 is IMPOSSIBLE for the official 46-shard checkpoint.
#
# Provenance + full rollback procedure:
#   docs/deepseek-v4-mtp1-fullgraph-validated-preset.md
# =============================================================================

VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
ENTRYPOINT_FILE=./entrypoints/entrypoint-rdma.sh
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048
VLLM_EXTRA_ARGS=--no-enable-prefix-caching --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling --compilation-config {"cudagraph_mode":"FULL_DECODE_ONLY","cudagraph_capture_sizes":[1],"cudagraph_num_of_warmups":2}
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2
