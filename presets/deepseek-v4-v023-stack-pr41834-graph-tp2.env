# =============================================================================
# deepseek-ai/DeepSeek-V4-Flash — SM12x EXPERIMENTAL graph variant (vLLM PR #41834)
#
# Status: EXPERIMENTAL. Not validated, not promoted, not production.
# NOT activated by default — run only after the bootstrap preset boots cleanly.
#
# Delta from deepseek-v4-v023-stack-pr41834-bootstrap-tp2.env:
#   GRAPH-related settings ONLY. Everything else (model, TP, EP-off, MTP-off,
#   prefix-cache-off, max_num_seqs=1, context, KV) is identical to bootstrap.
#     - CUDA graph ENABLED via cudagraph_mode=FULL_AND_PIECEWISE (the v1 default,
#       confirmed present in the pinned source's CUDAGraphMode enum).
#     - Breakable CUDA graph remains DISABLED (garbles on SM_121).
#     - Reserve cudagraph memory in the profiler (graph capture needs it).
#   MTP stays off; prefix caching stays off; do not combine with other variants.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model (FP8 base checkpoint, identical to bootstrap) ----
MODEL_PATH=[model_path]/deepseek-ai/deepseek-ai_DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# ---- Cluster (identical to bootstrap) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving (identical to bootstrap) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args (GRAPH delta: enforce-eager removed; cudagraph FULL_AND_PIECEWISE) ----
VLLM_EXTRA_ARGS=--no-enable-prefix-caching --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling --compilation-config {"cudagraph_mode":"FULL_AND_PIECEWISE"}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- vLLM SM_121 guards (GRAPH delta: estimate cudagraphs = 1) ----
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2
