VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
ENTRYPOINT_FILE=./entrypoints/entrypoint-rdma.sh
MODEL_PATH=/home/bjk110/Documents/Models/deepseek-ai/DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=10.10.10.1
WORKER_ROCE_IP=10.10.10.2
ROCE_IF_NAME=enp1s0f0np0
IB_HCA_NAME=rocep1s0f0
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048
VLLM_EXTRA_ARGS=--no-enable-prefix-caching --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling --speculative-config {"method":"deepseek_mtp","num_speculative_tokens":1} --compilation-config {"cudagraph_mode":"FULL_DECODE_ONLY","cudagraph_capture_sizes":[2],"cudagraph_num_of_warmups":2}
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2
