# =============================================================================
# deepseek-ai/DeepSeek-V4-Flash — SM12x EXPERIMENTAL prefix-cache variant (PR #41834)
#
# Status: EXPERIMENTAL. Not validated, not promoted, not production.
# NOT activated by default — run only after the bootstrap preset boots cleanly.
#
# Delta from deepseek-v4-v023-stack-pr41834-bootstrap-tp2.env:
#   PREFIX-CACHE-related settings ONLY. Everything else (model, TP, EP-off,
#   MTP-off, CUDA-graph-off / enforce-eager, max_num_seqs=1, context, KV) is
#   identical to bootstrap.
#     - Prefix caching ENABLED (--no-enable-prefix-caching removed).
#     - VLLM_PREFIX_CACHE_RETENTION_INTERVAL is the PR #43447 selective-retention
#       knob (confirmed present in the pinned source's envs.py). Left UNSET by
#       default; uncomment to experiment. Do NOT add a historical prefix-cache
#       write fence — that historical change is rejected (see provenance doc).
#   Graph stays off (enforce-eager); MTP stays off; max_num_seqs unchanged.
#   Do not combine with the graph variant.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model (FP8 base checkpoint, identical to bootstrap) ----
MODEL_PATH=[model_path]/deepseek-ai/deepseek-ai_DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# ---- Cluster (identical to bootstrap) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving (identical to bootstrap) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args (PREFIX-CACHE delta: prefix caching enabled; eager kept) ----
VLLM_EXTRA_ARGS=--enforce-eager --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- vLLM SM_121 guards (identical to bootstrap) ----
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- Prefix-cache experiment knob (PR #43447 selective retention) ----
# Confirmed present in the pinned source. Unset by default; uncomment to test.
# VLLM_PREFIX_CACHE_RETENTION_INTERVAL=<int>
