# =============================================================================
# deepseek-ai/DeepSeek-V4-Flash — SM12x EXPERIMENTAL tool-parser (PR #41834)
#
# Status: EXPERIMENTAL. Not validated, not promoted, not production.
#
# Derived verbatim from deepseek-v4-v023-stack-pr41834-reasoning-parser-tp2.env.
# The ONLY runtime difference from the reasoning-parser preset is two added
# VLLM_EXTRA_ARGS tokens:
#   --enable-auto-tool-choice      (let the model emit tool calls under auto)
#   --tool-call-parser deepseek_v4 (parse DeepSeek DSML tool_calls -> tool_calls)
# Everything else (image, model, cluster, serving limits, env, the
# tokenizer-mode + reasoning-parser tokens) is identical so a tool-vs-reasoning
# difference isolates to the tool-parser path alone.
#
# Registry confirmation (image
#   vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019,
#   id sha256:4c41950c47ecb771eead3e32147a750240d6605d15ee99c54b43e0a85ea26105,
#   source 72261a7af149fa5d3fe2ed2b9956e92590731012):
#   - ToolParserManager key "deepseek_v4" ->
#       vllm.tool_parsers.deepseekv4_tool_parser.DeepSeekV4ToolParser
#       (subclass of DeepSeekV32ToolParser in
#        vllm/tool_parsers/deepseekv32_tool_parser.py; manager in
#        vllm/tool_parsers/abstract_tool_parser.py)
#   - ReasoningParserManager key "deepseek_v4" ->
#       vllm.reasoning.deepseek_v4_reasoning_parser.DeepSeekV4ReasoningParser
#   - ChatMessage / DeltaMessage expose BOTH reasoning_content and tool_calls;
#       DeltaToolCall(id,type,index,function), DeltaFunctionCall(name,arguments)
#   - ChatCompletionRequest exposes tools, tool_choice, parallel_tool_calls,
#       chat_template_kwargs
#
# DSML grammar (V4 wraps V3.2 invoke/parameter grammar):
#   <｜DSML｜tool_calls> <｜DSML｜invoke name="fn">
#     <｜DSML｜parameter name="p" string="true|false">VALUE</｜DSML｜parameter>
#   </｜DSML｜invoke> </｜DSML｜tool_calls>
#   string="true"  -> value kept as raw string
#   string="false" -> coerce_to_schema_type() casts via schema (int/bool/number/
#                     array/object). A single "arguments"/"input" wrapper is
#                     unwrapped ONLY when that key is absent from the tool schema,
#                     so a user field literally named "arguments" is preserved.
#
# tool_choice support: DeepSeekV4ToolParser.supports_required_and_named = False.
#   The pinned source treats tool_choice="required" and named function choice the
#   SAME as "auto" (no forced structured constraint). tool_choice="none" disables
#   tool emission (adjust_request leaves DSML tokens skippable). Validation
#   therefore drives calls via auto + prompting, not via required/named.
#
# Reasoning + tools coexist: the reasoning parser populates reasoning_content from
#   <think>; the tool parser extracts DSML tool_calls from the post-think content.
#   thinking control is unchanged (chat_template_kwargs.{thinking|enable_thinking};
#   default thinking-on as observed at runtime; thinking=false -> Identity).
#
# Sampling for validation: temperature=1.0, top_p=1.0 (DeepSeek-V4 reference).
#
# Image / model / startup constraints are inherited unchanged from the bootstrap:
#   clean-memory preflight (~116-117 GiB CUDA-free/node), NO
#   VLLM_SKIP_INIT_MEMORY_CHECK, request approval before any reboot.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v023-stack-dsv4-sm12x-pr41834-exp-72261a7-tvmfam019
# Standard entrypoint — NO Step-3.7 tokenizer overlay (DeepSeek-V4 ships its own
# tokenizer; the overlay is Step-3.7-specific and must not be reused here).
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model (reasoning-parser run = same FP8 base checkpoint as bootstrap) ----
MODEL_PATH=[model_path]/deepseek-ai/deepseek-ai_DeepSeek-V4-Flash
MODEL_CONTAINER_PATH=/models/DeepSeek-V4-Flash
SERVED_MODEL_NAME=deepseek-ai/DeepSeek-V4-Flash

# ---- Cluster (dual DGX Spark, RoCE 200 Gbps, mp SPMD backend, no Ray) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving (conservative bootstrap) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args ----
# Reasoning-parser preset + the two tool-parser tokens (the only delta):
#   --enforce-eager            : CUDA graph OFF (graph is a separate experiment).
#   --no-enable-prefix-caching : prefix cache OFF (separate experiment).
#   --kv-cache-memory-bytes    : fixed 2 GiB KV pool (deterministic; avoids the
#                                profiling-run memory spike). Adjust upward only
#                                after a clean bring-up.
#   --skip-mm-profiling        : DeepSeek-V4-Flash is text-only here.
#   --tokenizer-mode deepseek_v4   : DeepSeek-V4 native tokenizer encoding.
#   --reasoning-parser deepseek_v4 : populate reasoning_content from <think>.
#   --enable-auto-tool-choice      : allow auto tool selection (required/named
#                                    fall back to auto for this parser).
#   --tool-call-parser deepseek_v4 : parse DSML tool_calls into tool_calls.
#   EP / MTP / sparse-MLA opt-ins / FlashInfer SM120 opt-ins: NOT added — let the
#     pinned source auto-select its DeepSeek-V4 path.
VLLM_EXTRA_ARGS=--enforce-eager --no-enable-prefix-caching --kv-cache-memory-bytes 2147483648 --kv-cache-dtype fp8 --skip-mm-profiling --tokenizer-mode deepseek_v4 --reasoning-parser deepseek_v4 --enable-auto-tool-choice --tool-call-parser deepseek_v4

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- vLLM SM_121 guards (v0.23-stack) ----
# Breakable CUDA graph default-on garbles on SM_121; keep disabled even though
# enforce-eager already prevents capture (belt-and-suspenders for the graph
# experiment that reuses this base).
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- Explicitly NOT set ----
# VLLM_SKIP_INIT_MEMORY_CHECK  : forbidden — rely on a clean-memory preflight.
# VLLM_USE_B12X_MOE / *_B12X_*  : not implemented in the pinned source.
# VLLM_PREFIX_CACHE_RETENTION_INTERVAL : prefix-cache experiment only.
# tool_choice="required" / named function choice : NOT forced — the deepseek_v4
#   tool parser does not support required/named (treated as auto); validation
#   drives calls via auto + prompting only.
