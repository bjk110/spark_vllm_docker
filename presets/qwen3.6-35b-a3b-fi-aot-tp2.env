# =============================================================================
# Qwen/Qwen3.6-35B-A3B — dual-node RDMA TP=2, FlashInfer AOT-prebaked image
#
# Architecture (Qwen3_5MoeForConditionalGeneration, hybrid MoE multimodal):
#   - model_type=qwen3_5_moe (wrapper config with nested text_config + vision_config)
#   - 40 layers (hybrid Mamba/Attention)
#   - hidden_size 2048, GQA 16→2, 256 experts, top-8 active (~3B active params)
#   - vocab 248320, max_position 262144 (served at 32768)
#
# Image: ghcr.io/bjk110/vllm-spark:v022-d568-fi-aot — thin overlay on v022-d568
#   (NGC 26.04 + vLLM 0.21.0+PR#35568 + FlashInfer 0.6.11.post3 + Transformers 5.8.1)
#   that AOT-promotes 7 FlashInfer SM120/SM121 kernel specs into spec.aot_path so
#   build_and_load() skips ninja at runtime.
#   Manifest digest: sha256:4e36c23864c95c941e1956cb0b4c5eb13490f8fac776606c0dab165c62912d1d
#   Build: dockerfiles/active/Dockerfile.v022-d568-fi-aot
#   For the non-AOT equivalent (single-node), use presets/qwen3.6-35b-a3b.env.
#
# Validated 2026-06-11: dual-node RDMA TP=2, Ray backend, Qwen3.6-35B-A3B.
#   - Ray join (2/2), model load, profiling, CUDA graph capture: all clean.
#   - All 7 FlashInfer specs is_aot=True / is_compiled=True on both nodes.
#   - Zero runtime ninja/nvcc/cicc/ptxas for the 7 prebaked specs.
#   - /health 200; /v1/completions returned valid completion.
#   - Memory/swap stable on both nodes throughout.
# Full notes: docs/flashinfer-aot-prebake.md
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v022-d568-fi-aot
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=[model_path]/Qwen/Qwen_Qwen3.6-35B-A3B
MODEL_CONTAINER_PATH=/models/Qwen3.6-35B-A3B
SERVED_MODEL_NAME=Qwen/Qwen3.6-35B-A3B

# ---- Cluster (dual-rdma TP=2) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving (validated at 0.85/32768/8/16384) ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=8
# 67 GB BF16 weights + activations + KV → 0.85 leaves ~18 GiB headroom
GPU_MEMORY_UTILIZATION=0.85
MAX_NUM_BATCHED_TOKENS=16384

# ---- Extra args ----
# --kv-cache-dtype fp8                : compress KV (model weights stay BF16)
# --reasoning-parser qwen3            : parse <think>...</think> as reasoning_content
# --enable-chunked-prefill            : reduce TTFT under concurrency
# --compilation-config use_inductor_graph_partition=true :
#     Qwen3.5/3.6 hybrid Mamba/Attention + torch.compile codegen workaround
# --limit-mm-per-prompt {"image":1,"audio":0,"video":0} :
#     wrapper arch has vision_config; allow 1 image, disable audio/video
VLLM_EXTRA_ARGS=--kv-cache-dtype fp8 --reasoning-parser qwen3 --enable-chunked-prefill --compilation-config {"use_inductor_graph_partition":true} --limit-mm-per-prompt {"image":1,"audio":0,"video":0}

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_NVLS_ENABLE=0
NCCL_DEBUG=WARN

# ---- Model-specific env vars (BF16, no static quantization) ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0

# ---- FlashInfer AOT arch selection ----
# Selects the "121a" JIT cache arch directory (SM121 on DGX Spark GB10).
# Required alongside the v022-d568-fi-aot image; harmless if removed but
# ensures FlashInfer resolves the prebaked .so files from the correct path.
FLASHINFER_CUDA_ARCH_LIST=12.1
