# =============================================================================
# stepfun-ai/Step-3.7-Flash-FP8 — dual DGX Spark GB10 TP=2 (2026-06-10)
#
# 198B-param sparse MoE VLM (196B LM + 1.8B vision encoder)
# ~11B active params/token, 288 experts top-8, standard FP8 block quant
# (e4m3, weight_block_size 128x128, dynamic activation — DeepSeek-V3 style)
#
# Image: v022-d568-ngc2605-tx5102-vllm022-step3p7 (NGC 26.05 + vLLM 0.22.1)
#   quant_method=fp8 uses vLLM's standard fp8.py path (NOT modelopt/NVFP4),
#   so the step3p7 NVFP4 input_scale patch does not trigger here — no rebuild
#   needed, same image as the NVFP4 deployment.
#
# Verified 2026-06-10: dual-rdma TP=2 boot OK, NaN-free /v1/completions,
# GPU KV cache size 80,308 tokens, max concurrency 2.45x @ 32768.
# Full guide: docs/step3.7-flash-tp2.md
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v022-d568-ngc2605-tx5102-vllm022-step3p7
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=[model_path]/stepfun-ai/Step-3.7-Flash-FP8
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-FP8
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-FP8

# ---- Cluster (replace placeholders with your dual-Spark RoCE values) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=<RAY_PORT>
DISTRIBUTED_BACKEND=ray

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args ----
# FP8 weights (~99GB/GPU at TP=2) leave far less headroom than NVFP4
# (~50GB/GPU). Pre-init memcheck reports only 106.41/121.63 GiB free at idle
# (no VLLM_SKIP_INIT_MEMORY_CHECK patch in this image) -> GPU_MEMORY_UTILIZATION
# capped near that ceiling. --enforce-eager skips CUDA graph capture.
# Post-profile KV cache check failed at util=0.85/batched=16384/seqs=4
# (rank0 -1.2 GiB, rank1 (RDMA worker node) -10.83 GiB; rank1
# activation/comm overhead ~9.5GiB higher than rank0). Cutting
# max_num_batched_tokens 16384->2048 and max_num_seqs 4->1 shrinks profiling
# activation memory enough for both ranks to clear the check (rank0 +6.6 GiB,
# rank1 +2.27 GiB) at util=0.87.
VLLM_EXTRA_ARGS=--trust-remote-code --enforce-eager --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2
