# =============================================================================
# stepfun-ai/Step-3.7-Flash-FP8 — vLLM 0.23 dual DGX Spark GB10 TP=2
# CURRENT VALIDATED Step-3.7 FP8 BASELINE (main Step-3.7 FP8 serving path).
#
# Status: current validated baseline. This is the main Step-3.7 *FP8* path on
#   vLLM 0.23; it does NOT replace the Step-3.7 NVFP4 preset and is NOT a global
#   production default for all models. NVFP4 remains a separate, unchanged path.
#
# Model: stepfun-ai/Step-3.7-Flash-FP8
#   revision b3d7916fccac844cca050d7520f2aaa513f9a84f
#   arch Step3p7ForConditionalGeneration; 198B sparse MoE VLM (196B LM +
#   1.8B vision encoder), 288 experts top-8. Quant: FP8, dynamic activation,
#   E4M3, weight_block_size [128,128] (DeepSeek-V3-style) -> vLLM fp8.py path.
#
# Image (immutable, published; do NOT rebuild/retag):
#   ghcr.io/bjk110/vllm-spark:v023-step37-tokenizer-overlay-exp-07a2722
#   manifest digest sha256:1c987173177a69d58d2ce61babf874f1a7c6c9a2830dcd33b180f2d81c9fde1e
#   config/image id sha256:f195d6e15041743c6b8bb95dfbf47305fa3c11b60d1272c4001baf877ab6e1fa
#   platform linux/arm64. Thin layer on the Prometheus-fix base
#   (sha256:81653ff7...); includes the prometheus-fastapi-instrumentator
#   routing.py compatibility fix (sha256:a3addfd9...) so /metrics and all
#   endpoints return 200 on vLLM 0.23 (no _IncludedRouter 500).
#
# Tokenizer overlay (REQUIRED): the model dir ships
#   tokenizer_config.json tokenizer_class=LlamaTokenizerFast, which Transformers
#   5.10.2 resolves to a broken slow tokenizer (drops Korean). The image's
#   wrapper entrypoint generates a non-mutating overlay under /run (class ->
#   PreTrainedTokenizerFast) and injects --tokenizer at startup, leaving the
#   model directory read-only and upstream-like. ENTRYPOINT_FILE +
#   TOKENIZER_OVERLAY_ENABLE=1 below are both required. The synchronized model
#   directories (homeserver, spark01, spark02) MUST retain the upstream-like
#   tokenizer metadata (source SHA256 78202af4...); do NOT edit
#   tokenizer_config.json in place. See docs/step3.7-tokenizer-overlay.md.
#
# Validated scope (2026-06-21): TP=2, EP off, MAX_MODEL_LEN=8192, concurrency=1.
#   6/6 correctness (Korean preserved, no Ġ/Ċ). MoE backend = automatic TRITON
#   Fp8 fused MoE (NOT forced); text attention TRITON_ATTN; ViT FLASH_ATTN
#   (runtime-selected). Larger context (>8192) and higher concurrency are
#   UNVALIDATED. llama-benchy 0.3.7 baseline: see docs/step3.7-tokenizer-overlay.md.
#
# Startup (GB10 UMA): require a clean-memory preflight before loading. The
#   validated clean range is ~116-117 GiB CUDA-free per node. A large-model
#   shutdown can leave substantial UVM/driver-retained memory; drop_caches does
#   NOT recover non-page-cache retention. A reboot may be required — request
#   explicit approval before rebooting nodes.
# =============================================================================

# ---- Image ----
VLLM_IMAGE=ghcr.io/bjk110/vllm-spark:v023-step37-tokenizer-overlay-exp-07a2722
# Tokenizer-overlay wrapper entrypoint (bind-mounted to /entrypoint.sh); it
# generates the overlay and exec()s the baked standard entrypoint.
ENTRYPOINT_FILE=./entrypoints/entrypoint-tokenizer-overlay.sh
# Enable the non-mutating tokenizer overlay (required for correct Korean output).
TOKENIZER_OVERLAY_ENABLE=1

# ---- Model ----
MODEL_PATH=[model_path]/stepfun-ai/Step-3.7-Flash-FP8
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-FP8
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-FP8

# ---- Cluster (dual DGX Spark, RoCE 200 Gbps, mp SPMD backend) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving (validated baseline) ----
HOST_PORT=8000
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.87
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args ----
# FP8 validated baseline (single-stream conservative):
#   (no --quantization)       : quant_method=fp8 auto-detected -> fp8.py.
#   (no --moe-backend)        : FP8 MoE auto-selects TRITON Fp8 (do NOT force
#                               marlin — that is NVFP4-specific).
#   (no --enable-expert-parallel): EP disabled (validated topology).
#   --enforce-eager           : CUDA graph disabled (memory headroom; avoids the
#                               SM_121 breakable-cudagraph garble path).
#   --attention-backend TRITON_ATTN : confirmed-safe on SM_121 (FlashInfer
#                               reasoning garbles on vLLM 0.23). ViT uses FLASH_ATTN.
#   --kv-cache-memory-bytes 2147483648 : fixed 2 GiB KV pool (default-auto bf16 KV).
#   --no-enable-prefix-caching / --skip-mm-profiling : reduce startup memory and
#                               variability for the text baseline.
#   --reasoning-parser/--tool-call-parser step3p5 : required for this model.
# NOTE: --tokenizer is NOT set here; the overlay wrapper injects it at runtime.
VLLM_EXTRA_ARGS=--enforce-eager --attention-backend TRITON_ATTN --kv-cache-memory-bytes 2147483648 --no-enable-prefix-caching --skip-mm-profiling --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- vLLM 0.23 SM_121 guards ----
VLLM_USE_BREAKABLE_CUDAGRAPH=0
# enforce-eager => no CUDA graph capture, so do not reserve cudagraph memory.
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
# NVFP4-only ModelOpt MoE cache release: irrelevant to FP8, keep off.
VLLM_SPARK_EMPTY_CACHE_AFTER_MODELOPT_MOE=0
# GB10 UMA: bypass the pre-init memcheck (mem_get_info tracks MemFree; local
# checkpoint page cache can depress it below util*total at startup). This is the
# validated bypass for THIS path only; do not extend to unvalidated configs.
VLLM_SKIP_INIT_MEMORY_CHECK=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2
