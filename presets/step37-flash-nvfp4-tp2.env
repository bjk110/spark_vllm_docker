# =============================================================================
# stepfun-ai/Step-3.7-Flash-NVFP4 — dual DGX Spark GB10 TP=2 (v0.22 EP-on)
#
# EXPERIMENTAL — long-context (262k) multiprocessing-backend profile.
# BLOCKED: This image lacks patch_skip_init_memory_check.py. On GB10 with
# driver 610, CUDA free memory (~50 GiB) is less than GPU_UTIL × total
# (0.88 × 121.63 = 107 GiB), causing request_memory() to fail at startup.
# Reboot does not resolve this; the driver baseline (~71 GiB) is too large.
# Fix: rebuild the image with the three bypass patches from Dockerfile.step3p7-v023
# and set VLLM_SKIP_INIT_MEMORY_CHECK=1, then re-run the Stage A ladder.
# See docs/benchmarks/step37-v022-long-context-validation.md for full details.
# Do not use for production serving.
#
# For the validated production path see:
#   presets/step37-flash-nvfp4-v023-tp2-latency.env  (vLLM 0.23, VALIDATED)
#
# 198B-param sparse MoE VLM (196B LM + 1.8B vision encoder)
# ~11B active params/token, 288 experts top-8, NVFP4 (modelopt) + FP8 KV
#
# Image: v022-d568-ngc2605-tx5102-vllm022-step3p7-modelopt-cache-release
#        (NGC 26.05 + vLLM 0.22.1 + Step3p7 support + NVFP4 input_scale fix
#         + ModelOpt NVFP4 MoE per-module cache-release workaround)
# Ref:   stepfun-ai README vLLM NVFP4 recipe
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v022-d568-ngc2605-tx5102-vllm022-step3p7-modelopt-cache-release
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=[model_path]/stepfun-ai/Step-3.7-Flash-NVFP4
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-NVFP4
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-NVFP4

# ---- Cluster (replace placeholders with your dual-Spark RoCE values) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379          # unused in mp backend; kept for quick switch back to ray
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=262144
MAX_NUM_SEQS=4
GPU_MEMORY_UTILIZATION=0.88
MAX_NUM_BATCHED_TOKENS=8192

# ---- Extra args ----
# --quantization modelopt   : NVFP4 modelopt format (NOT compressed-tensors)
# --kv-cache-dtype fp8      : KV cache FP8 as specified in hf_quant_config.json
# --enable-expert-parallel  : distribute MoE experts across TP ranks (288 experts / 2)
# --reasoning-parser step3p5: Step3p5 reasoning field parsing
# --tool-call-parser step3p5: Step3p5 tool call parsing
# Note: --enforce-eager is NOT used — NVFP4 runs CUDA graphs successfully
VLLM_EXTRA_ARGS=--trust-remote-code --quantization modelopt --kv-cache-dtype fp8 --enable-expert-parallel --no-enable-flashinfer-autotune --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5

# ---- Runtime env ----
# Required on DGX Spark GB10 for the ModelOpt NVFP4 MARLIN post-load conversion
# path to prevent cumulative CUDA caching-allocator reserved-memory growth.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:False
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- NVFP4 model-specific ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
VLLM_NVFP4_GEMM_BACKEND=cutlass

# ---- ModelOpt NVFP4 MoE cache-release workaround ----
# Required on DGX Spark GB10 for the ModelOpt NVFP4 MARLIN post-load conversion
# path to prevent cumulative CUDA caching-allocator reserved-memory growth.
# 42 ModelOptNvFp4FusedMoE modules are flushed during weight loading.
# Cumulative overhead: <0.5 s per rank in the validated dual-Spark GB10 config.
VLLM_SPARK_EMPTY_CACHE_AFTER_MODELOPT_MOE=1
