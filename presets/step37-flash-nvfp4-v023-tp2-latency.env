# =============================================================================
# stepfun-ai/Step-3.7-Flash-NVFP4 — v0.23 Series A latency preset (2026-06-18)
#
# Scope: single-user latency-oriented serving on dual DGX Spark GB10 (SM_121).
#   TP=2, EP disabled, MAX_NUM_SEQS=1. Validated under Series A conditions:
#   correctness-safe MARLIN MoE + TRITON_ATTN attention backends, CUDA graph
#   disabled. bt=2048 is the preferred measured value from a full bt sweep
#   (bt=256, bt=2048, bt=8192 all measured 2026-06-18).
#
# This preset is NOT for:
#   - multi-user / high-concurrency serving (MAX_NUM_SEQS=1 limits throughput)
#   - EP-on topologies (--enable-expert-parallel absent)
#   - FlashInfer attention (garbles on SM_121 with NVFP4 in vLLM 0.23)
#   - CUDA graph enabled (vLLM 0.23 CUDA graph path garbles on SM_121 NVFP4)
#   - MAX_MODEL_LEN > 32768 without re-validation of memory headroom
#   - Other models or quantization formats
#
# Benchmark reference: docs/benchmarks/bt-matrix-step37-nvfp4-v023.md
# Validated config: run_id=bt2048-20260618-093121, image sha matches below.
#
# Image: v023-step3p7-fixed-kv-profile-skip-candidate
#   Built on NGC 26.05 + vLLM 0.23.0 with patches:
#     1. VLLM_SKIP_INIT_MEMORY_CHECK env registration + bypass
#     2. post-profile assertion relaxed for GB10 UMA page-cache variation
#     3. VLLM_SPARK_SKIP_FIXED_KV_PROFILE_RUN (set to 0 here — profile run
#        needed for EP dispatch initialisation even in EP-off mode)
# =============================================================================

# ---- Image ----
VLLM_IMAGE=vllm-spark:v023-step3p7-fixed-kv-profile-skip-candidate
ENTRYPOINT_FILE=./entrypoints/entrypoint.sh

# ---- Model ----
MODEL_PATH=[model_path]/stepfun-ai/Step-3.7-Flash-NVFP4
MODEL_CONTAINER_PATH=/models/Step-3.7-Flash-NVFP4
SERVED_MODEL_NAME=stepfun-ai/Step-3.7-Flash-NVFP4

# ---- Cluster (dual DGX Spark, RoCE 200 Gbps) ----
CLUSTER_MODE=dual-rdma
TP_SIZE=2
HEAD_ROCE_IP=<HEAD_ROCE_IP>
WORKER_ROCE_IP=<WORKER_ROCE_IP>
ROCE_IF_NAME=<ROCE_IF_NAME>
IB_HCA_NAME=<IB_HCA_NAME>
RAY_PORT=6379
DISTRIBUTED_BACKEND=mp
MASTER_PORT=29500

# ---- vLLM Serving ----
HOST_PORT=8000
MAX_MODEL_LEN=32768
MAX_NUM_SEQS=1
GPU_MEMORY_UTILIZATION=0.79
MAX_NUM_BATCHED_TOKENS=2048

# ---- Extra args ----
# Series A (EP-off, MARLIN, TRITON_ATTN, no CUDA graph, fixed 2 GiB KV):
#   --moe-backend marlin      : REQUIRED — vLLM 0.23 auto-selects CUTLASS for
#                               NVFP4, which produces garbled output on SM_121.
#   --attention-backend TRITON_ATTN : REQUIRED — FlashInfer reasoning garble on
#                               SM_121 in vLLM 0.23. TRITON_ATTN is garble-free.
#   --compilation-config ...  : CUDA graph disabled. SM_121 NVFP4 CUDA graph
#                               path produces garble via VLLM_USE_BREAKABLE_CUDAGRAPH.
#   --kv-cache-memory-bytes   : Fixed 2 GiB KV. This was the benchmark-controlled
#                               value; increase carefully if larger context windows
#                               are needed (re-validate memory headroom at 0.79 util).
#   NO --enable-expert-parallel : Series A defining characteristic (EP disabled).
VLLM_EXTRA_ARGS=--trust-remote-code --quantization modelopt --kv-cache-dtype fp8 --no-enable-flashinfer-autotune --reasoning-parser step3p5 --enable-auto-tool-choice --tool-call-parser step3p5 --no-enable-prefix-caching --skip-mm-profiling --kv-cache-memory-bytes 2147483648 --compilation-config {"mode":0,"cudagraph_mode":"NONE"} --moe-backend marlin --attention-backend TRITON_ATTN

# ---- Runtime env ----
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
NCCL_IB_DISABLE=0
NCCL_DEBUG=WARN
NCCL_NVLS_ENABLE=0
NCCL_NET=Socket

# ---- Critical: vLLM 0.23 SM_121 guards ----
VLLM_USE_BREAKABLE_CUDAGRAPH=0
VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=0

# ---- Patch toggles ----
APPLY_TEXT_ONLY_SHIM=0
VLLM_SPARK_EMPTY_CACHE_AFTER_MODELOPT_MOE=1

# ---- GB10 UMA memory check bypass ----
# Required when the host UMA has residual pages from a prior container stop.
# The post-stop residual (~53 GiB free vs 121 GiB total) causes the vLLM
# pre-init memory assertion to fail without this bypass. Reboot recovers
# the full 121 GiB; this flag allows starting without a reboot.
VLLM_SKIP_INIT_MEMORY_CHECK=1

# ---- Fixed KV profile run ----
# VLLM_SPARK_SKIP_FIXED_KV_PROFILE_RUN=1 would skip profile in fixed-KV branch.
# Keep at 0: profile run is needed for expert-dispatch initialisation (even EP-off).
VLLM_SPARK_SKIP_FIXED_KV_PROFILE_RUN=0

# ---- NGC 26.05 specifics ----
FLASHINFER_CUDA_ARCH_LIST=12.1
VLLM_USE_RAY_V2_EXECUTOR_BACKEND=0
VLLM_NCCL_SO_PATH=/usr/lib/aarch64-linux-gnu/libnccl.so.2

# ---- NVFP4 model-specific ----
VLLM_MARLIN_USE_ATOMIC_ADD=0
VLLM_USE_FLASHINFER_MOE_FP4=0
